# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore.

# ── Friday Dealer API ─────────────────────────────────────────────────────────
# Your Friday Dealer API key (server-side only — no NEXT_PUBLIC_ prefix)
FRIDAY_API_KEY=frd_your_key_here

# Base URL for the Friday Dealer API (no trailing slash).
# Only set this if your dealer uses a custom subdomain — the default is correct
# for most Friday Dealer accounts.
# FRIDAY_API_BASE_URL=https://fridaydealer.com

# ── Optional tuning ───────────────────────────────────────────────────────────
# Seconds between inventory re-fetches in production (default: 60).
# Friday Dealer allows max 60 requests/min — keep this at 60 or higher.
# FRIDAY_REVALIDATE_SECONDS=60
